<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:id="@+id/text"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:gravity="center"
        android:layout_marginTop="@dimen/dimen_space_10"
        android:text="@string/ring_duration"
        android:textSize="15sp" />
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="?attr/ColorDarkLight"
        android:layout_marginLeft="@dimen/dimen_space_15"
        android:layout_marginRight="@dimen/dimen_space_15"/>

</LinearLayout>