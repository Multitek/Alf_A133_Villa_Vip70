<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.intercom.SetStreamVolumeActivity">


    <LinearLayout
        android:layout_width="600dp"
        android:layout_height="wrap_content"
        android:background="@color/bar_back"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="500dp"
            android:layout_height="70dp"
            android:layout_margin="@dimen/dimen_space_5"
            android:orientation="horizontal"
            tools:ignore="UseCompoundDrawables">

            <ImageView
                android:id="@+id/img_back"
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:layout_gravity="start"
                android:layout_marginStart="5dp"
                android:src="@drawable/ic_back"
                app:tint="@color/white" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center|start"
                android:text="@string/set_volume_settings"
                android:textColor="@color/white"
                android:textSize="36sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/ln1"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="@dimen/dimen_space_10"
            android:gravity="center|bottom"
            android:text="@string/set_door_volume"
            android:textColor="@color/white"
            android:textSize="32sp" />

        <LinearLayout
            android:id="@+id/ln2"
            android:layout_width="480dp"
            android:layout_height="2dp"
            android:layout_marginTop="@dimen/dimen_space_5"
            android:background="@color/white"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/ln3"
            android:layout_width="500dp"
            android:layout_height="120dp"
            android:layout_marginTop="@dimen/dimen_space_5"
            android:gravity="center">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/img_minus_door"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginStart="@dimen/dimen_space_10"
                android:layout_marginEnd="@dimen/dimen_space_10"
                android:src="@drawable/ic_baseline_volume_down_24" />


            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/txt_val_door"
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/dimen_space_30"
                android:layout_marginEnd="@dimen/dimen_space_40"
                android:gravity="center"
                android:text="5"
                android:textColor="@color/white"
                android:textSize="80sp" />


            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/img_plus_door"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_marginStart="@dimen/dimen_space_10"
                android:layout_marginEnd="@dimen/dimen_space_10"
                android:src="@drawable/ic_baseline_volume_up_24" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="@dimen/dimen_space_15"
            android:gravity="center|bottom"
            android:text="@string/set_room_volume"
            android:textColor="@color/white"
            android:textSize="32sp" />

        <LinearLayout
            android:layout_width="480dp"
            android:layout_height="2dp"
            android:layout_marginTop="@dimen/dimen_space_5"
            android:background="@color/white"
            android:orientation="vertical" />

        <LinearLayout
            android:layout_width="500dp"
            android:layout_height="120dp"
            android:layout_marginTop="@dimen/dimen_space_5"
            android:gravity="center">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/img_minus_room"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginStart="@dimen/dimen_space_10"
                android:layout_marginEnd="@dimen/dimen_space_10"
                android:src="@drawable/ic_baseline_volume_down_24" />


            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/txt_val_room"
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/dimen_space_30"
                android:layout_marginEnd="@dimen/dimen_space_40"
                android:gravity="center"
                android:text="5"
                android:textColor="@color/white"
                android:textSize="80sp" />


            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/img_plus_room"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_marginStart="@dimen/dimen_space_10"
                android:layout_marginEnd="@dimen/dimen_space_10"
                android:src="@drawable/ic_baseline_volume_up_24" />

        </LinearLayout>


    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>