<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_margin="@dimen/dimen_space_5"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="180dp"
                android:layout_height="match_parent"
                android:layout_margin="5dp"
                android:gravity="start|center"
                android:text="@string/settings_sleep_options"
                android:textSize="22sp" />

            <androidx.cardview.widget.CardView
                android:layout_width="250dp"
                android:layout_gravity="center_vertical"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/layout_sleep"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:gravity="start"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/layout_sleep_click"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/text_sleep_title"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.75"
                            android:gravity="center"
                            tools:text="test"
                            android:textSize="20sp" />

                        <ImageView
                            android:id="@+id/img_expand_collapse_sleep"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_gravity="end"
                            android:layout_weight="0.1"
                            android:contentDescription="@string/content_description"
                            android:padding="3dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_expand" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:layout_marginTop="@dimen/dimen_space_5"
                        android:layout_marginLeft="@dimen/dimen_space_5"
                        android:layout_marginRight="@dimen/dimen_space_5"
                        android:background="@color/peru" />


                    <TextView
                        android:id="@+id/sleepNever"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="@dimen/dimen_space_10"
                        android:gravity="center"
                        android:text="@string/never_sleep"
                        android:textSize="15sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="?attr/ColorDarkLight"
                        android:layout_marginLeft="@dimen/dimen_space_15"
                        android:layout_marginRight="@dimen/dimen_space_15" />


                    <TextView
                        android:id="@+id/sleep2"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="@dimen/dimen_space_10"
                        android:gravity="center"
                        android:text="@string/sleep_2"
                        android:textSize="15sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="?attr/ColorDarkLight"
                        android:layout_marginLeft="@dimen/dimen_space_15"
                        android:layout_marginRight="@dimen/dimen_space_15" />

                    <TextView
                        android:id="@+id/sleep5"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="@dimen/dimen_space_10"
                        android:gravity="center"
                        android:text="@string/sleep_5"
                        android:textSize="15sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="?attr/ColorDarkLight"
                        android:layout_marginLeft="@dimen/dimen_space_15"
                        android:layout_marginRight="@dimen/dimen_space_15" />

                    <TextView
                        android:id="@+id/sleep10"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="@dimen/dimen_space_10"
                        android:gravity="center"
                        android:text="@string/sleep_10"
                        android:textSize="15sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="?attr/ColorDarkLight"
                        android:layout_marginLeft="@dimen/dimen_space_15"
                        android:layout_marginRight="@dimen/dimen_space_15" />

                    <TextView
                        android:id="@+id/sleep30"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="@dimen/dimen_space_10"
                        android:gravity="center"
                        android:text="@string/sleep_30"
                        android:textSize="15sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="180dp"
                android:layout_height="match_parent"
                android:text="@string/brightness"
                android:layout_margin="5dp"
                android:gravity="start|center"
                android:textSize="22sp" />


            <androidx.cardview.widget.CardView
                android:layout_width="250dp"
                android:layout_marginStart="5dp"
                android:layout_height="match_parent">
                <SeekBar
                    android:id="@+id/seekBarBrightness"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="@dimen/dimen_space_5"
                    android:max="255" />

            </androidx.cardview.widget.CardView>


        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/theme_card"
            android:layout_width="300dp"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/dimen_space_30"
            android:layout_height="80dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="5dp"
                android:gravity="center"
                android:text="@string/theme_settings"
                android:textSize="22sp" />

        </androidx.cardview.widget.CardView>



    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>