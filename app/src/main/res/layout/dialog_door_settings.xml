<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="100dp"
        android:layout_marginTop="@dimen/dimen_space_40"
        android:layout_marginEnd="100dp"
        android:layout_marginBottom="@dimen/dimen_space_40"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_margin="@dimen/dimen_space_5"
                app:layout_constraintBottom_toTopOf="@id/layout_bottom">

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fillViewport="true"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintVertical_bias="0.5">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical">

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginStart="@dimen/dimen_space_30"
                            android:layout_marginEnd="@dimen/dimen_space_30"
                            app:cardBackgroundColor="?attr/ColorDarkLightOnStroke"
                            app:cardUseCompatPadding="true">

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/text_input_device_name"
                                android:layout_width="match_parent"
                                android:layout_height="90dp"
                                android:layout_gravity="center"
                                android:layout_marginStart="@dimen/dimen_space_10"
                                android:layout_marginTop="@dimen/dimen_space_5"
                                android:layout_marginEnd="@dimen/dimen_space_10"
                                android:focusable="true"
                                android:focusableInTouchMode="true"
                                android:hint="@string/enter_door_name"
                                app:counterEnabled="true"
                                app:counterMaxLength="20"
                                app:counterOverflowTextAppearance="@style/counterOverride"
                                app:counterTextAppearance="@style/counterText"
                                app:errorEnabled="true">

                                <EditText
                                    android:id="@+id/ed_door_name"
                                    android:layout_width="match_parent"
                                    android:layout_height="50dp"
                                    android:layout_gravity="center"
                                    android:gravity="center"
                                    android:hint="@string/empty"
                                    android:imeOptions="actionDone"
                                    android:importantForAutofill="no"
                                    android:inputType="textPersonName"
                                    android:maxLength="21"
                                    android:textAllCaps="false"
                                    android:textSize="22sp" />

                            </com.google.android.material.textfield.TextInputLayout>
                        </androidx.cardview.widget.CardView>

                        <CheckBox
                            android:id="@+id/cbMaster"
                            android:layout_width="wrap_content"
                            android:layout_height="50dp"
                            android:layout_gravity="center"
                            android:layout_marginTop="5dp"
                            android:gravity="center"
                            android:padding="@dimen/dimen_space_5"
                            android:text="@string/door_settings_set_master"
                            android:textSize="22sp" />

                        <LinearLayout
                            android:id="@+id/layoutRelaySettings"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dimen_space_20"
                            android:layout_marginStart="@dimen/dimen_space_30"
                            android:layout_marginEnd="@dimen/dimen_space_30"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:visibility="gone"
                            tools:visibility="visible">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="60dp"
                                android:layout_gravity="center"
                                android:background="@drawable/layer3"
                                android:gravity="center"
                                android:orientation="horizontal">

                                <androidx.cardview.widget.CardView
                                    android:layout_width="130dp"
                                    android:layout_gravity="center_vertical"
                                    android:layout_height="match_parent"
                                    android:layout_marginTop="@dimen/dimen_space_10"
                                    android:layout_marginBottom="@dimen/dimen_space_10"
                                    android:layout_marginStart="@dimen/dimen_space_10"
                                    android:layout_marginEnd="@dimen/dimen_space_5"
                                    app:cardBackgroundColor="?attr/ColorDarkLightOnStroke">

                                    <Spinner
                                        android:id="@+id/spnRelay1"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        tools:ignore="SpeakableTextPresentCheck" />

                                </androidx.cardview.widget.CardView>

                                <RadioButton
                                    android:id="@+id/rb_relay1"
                                    android:layout_width="150dp"
                                    android:layout_height="match_parent"
                                    android:layout_marginEnd="@dimen/dimen_space_10"
                                    android:checked="true"
                                    android:gravity="start|center_vertical"
                                    android:text="@string/relay_count_1"
                                    android:textSize="21sp" />

                                <RadioButton
                                    android:id="@+id/rb_relay2"
                                    android:layout_width="150dp"
                                    android:layout_height="match_parent"
                                    android:layout_marginStart="@dimen/dimen_space_10"
                                    android:checked="false"
                                    android:gravity="start|center_vertical"
                                    android:text="@string/relay_count_2"
                                    android:textSize="21sp" />

                                <androidx.cardview.widget.CardView
                                    android:layout_width="130dp"
                                    android:layout_gravity="center_vertical"
                                    android:layout_height="match_parent"
                                    android:layout_marginTop="@dimen/dimen_space_10"
                                    android:layout_marginBottom="@dimen/dimen_space_10"
                                    android:layout_marginStart="@dimen/dimen_space_5"
                                    android:layout_marginEnd="@dimen/dimen_space_10"
                                    app:cardBackgroundColor="?attr/ColorDarkLightOnStroke">

                                    <Spinner
                                        android:id="@+id/spnRelay2"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        tools:ignore="SpeakableTextPresentCheck" />

                                </androidx.cardview.widget.CardView>


                            </LinearLayout>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/cardview_relay1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginTop="@dimen/dimen_space_5"
                                app:cardBackgroundColor="?attr/ColorDarkLightOnStroke"
                                app:cardUseCompatPadding="true">

                                <com.google.android.material.textfield.TextInputLayout
                                    android:id="@+id/text_input_relay1_name"
                                    android:layout_width="match_parent"
                                    android:layout_height="90dp"
                                    android:layout_gravity="center"
                                    android:layout_marginStart="@dimen/dimen_space_10"
                                    android:layout_marginTop="@dimen/dimen_space_5"
                                    android:layout_marginEnd="@dimen/dimen_space_10"
                                    android:focusable="true"
                                    android:focusableInTouchMode="true"
                                    android:hint="@string/enter_relay_1_name"
                                    app:counterEnabled="true"
                                    app:counterMaxLength="20"
                                    app:counterOverflowTextAppearance="@style/counterOverride"
                                    app:counterTextAppearance="@style/counterText"
                                    app:errorEnabled="true">

                                    <EditText
                                        android:id="@+id/ed_relay1_name"
                                        android:layout_width="match_parent"
                                        android:layout_height="50dp"
                                        android:layout_gravity="center"
                                        android:gravity="center"
                                        android:hint="@string/empty"
                                        android:imeOptions="actionDone"
                                        android:importantForAutofill="no"
                                        android:inputType="textPersonName"
                                        android:maxLength="21"
                                        android:textAllCaps="false"
                                        android:textSize="22sp" />

                                </com.google.android.material.textfield.TextInputLayout>
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/cardview_relay2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal"
                                android:layout_marginTop="@dimen/dimen_space_5"
                                app:cardBackgroundColor="?attr/ColorDarkLightOnStroke"
                                app:cardUseCompatPadding="true">

                                <com.google.android.material.textfield.TextInputLayout
                                    android:id="@+id/text_input_relay2_name"
                                    android:layout_width="match_parent"
                                    android:layout_height="90dp"
                                    android:layout_gravity="center"
                                    android:layout_marginStart="@dimen/dimen_space_10"
                                    android:layout_marginTop="@dimen/dimen_space_5"
                                    android:layout_marginEnd="@dimen/dimen_space_10"
                                    android:focusable="true"
                                    android:focusableInTouchMode="true"
                                    android:hint="@string/enter_relay_2_name"
                                    app:counterEnabled="true"
                                    app:counterMaxLength="20"
                                    app:counterOverflowTextAppearance="@style/counterOverride"
                                    app:counterTextAppearance="@style/counterText"
                                    app:errorEnabled="true">

                                    <EditText
                                        android:id="@+id/ed_relay2_name"
                                        android:layout_width="match_parent"
                                        android:layout_height="50dp"
                                        android:layout_gravity="center"
                                        android:gravity="center"
                                        android:hint="@string/empty"
                                        android:imeOptions="actionDone"
                                        android:importantForAutofill="no"
                                        android:inputType="textPersonName"
                                        android:maxLength="21"
                                        android:textAllCaps="false"
                                        android:textSize="22sp" />

                                </com.google.android.material.textfield.TextInputLayout>
                            </androidx.cardview.widget.CardView>
                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_marginStart="@dimen/dimen_space_30"
                            android:layout_marginEnd="@dimen/dimen_space_30"
                            android:layout_height="25dp"
                            android:layout_marginTop="@dimen/dimen_space_15"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="180dp"
                                android:layout_height="match_parent"
                                android:gravity="center_vertical"
                                android:text="@string/fw_version"
                                android:textSize="18sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:gravity="center_vertical"
                                android:text="@string/two_dots"
                                android:textSize="18sp" />

                            <TextView
                                android:id="@+id/fw_version"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginStart="2dp"
                                android:gravity="center_vertical"
                                android:textSize="17sp"
                                tools:text="sdsdf" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_marginStart="@dimen/dimen_space_30"
                            android:layout_marginEnd="@dimen/dimen_space_30"
                            android:layout_height="25dp"
                            android:layout_marginTop="@dimen/dimen_space_5"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="180dp"
                                android:layout_height="match_parent"
                                android:gravity="center_vertical"
                                android:text="@string/app_version"
                                android:textSize="18sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:gravity="center_vertical"
                                android:text="@string/two_dots"
                                android:textSize="18sp" />

                            <TextView
                                android:id="@+id/apk_version"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginStart="2dp"
                                android:gravity="center_vertical"
                                android:textSize="17sp"
                                tools:text="sdsdf" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_marginStart="@dimen/dimen_space_30"
                            android:layout_marginEnd="@dimen/dimen_space_30"
                            android:layout_height="25dp"
                            android:layout_marginTop="@dimen/dimen_space_5"
                            android:layout_marginBottom="@dimen/dimen_space_5"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="180dp"
                                android:layout_height="match_parent"
                                android:gravity="center_vertical"
                                android:text="@string/mac_address"
                                android:textSize="18sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:gravity="center_vertical"
                                android:text="@string/two_dots"
                                android:textSize="18sp" />

                            <TextView
                                android:id="@+id/txtMacAddr"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginStart="2dp"
                                android:gravity="center_vertical"
                                android:textSize="17sp"
                                tools:text="sdsdf" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_marginStart="@dimen/dimen_space_30"
                            android:layout_marginEnd="@dimen/dimen_space_30"
                            android:layout_height="25dp"
                            android:layout_marginTop="@dimen/dimen_space_5"
                            android:layout_marginBottom="@dimen/dimen_space_5"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="180dp"
                                android:layout_height="match_parent"
                                android:gravity="center_vertical"
                                android:text="@string/staticIpMode"
                                android:textSize="18sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:gravity="center_vertical"
                                android:text="@string/two_dots"
                                android:textSize="18sp" />

                            <TextView
                                android:id="@+id/txtStaticIp"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginStart="2dp"
                                android:gravity="center_vertical"
                                android:textSize="17sp"
                                tools:text="sdsdf" />

                        </LinearLayout>
                    </LinearLayout>
                </ScrollView>
            </androidx.constraintlayout.widget.ConstraintLayout>



            <LinearLayout
                android:id="@+id/layout_bottom"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">


                <Button
                android:textStyle="bold"
                    android:id="@+id/btnCancel"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="160dp"
                    android:layout_height="60dp"
                    android:layout_marginStart="@dimen/dimen_space_15"
                    android:layout_marginEnd="@dimen/dimen_space_15"
                    android:background="@drawable/layer3"
                    android:gravity="center"
                    android:text="@string/cancel"
                    android:textAllCaps="true"
                    android:textSize="19sp" />


                <Button
                android:textStyle="bold"
                    android:id="@+id/btnSave"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="160dp"
                    android:layout_height="60dp"
                    android:layout_marginStart="@dimen/dimen_space_15"
                    android:layout_marginEnd="@dimen/dimen_space_15"
                    android:background="@drawable/layer3"
                    android:gravity="center"
                    android:text="@string/save"
                    android:textAllCaps="true"
                    android:textSize="19sp" />

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>
