<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <include
        android:id="@+id/include_top"
        layout="@layout/bar_top"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <androidx.cardview.widget.CardView
        android:id="@+id/card_scenarios"
        android:layout_width="260dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/dimen_space_5"
        android:layout_marginBottom="@dimen/dimen_space_5"
        android:orientation="vertical"
        app:cardBackgroundColor="@color/divider"
        app:layout_constraintBottom_toTopOf="@+id/include_bottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/include_top">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">


            <TextView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.07"
                android:gravity="center"
                android:text="@string/smart_scenarios"
                android:textAllCaps="true"
                android:textColor="@color/white"
                android:textSize="25sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="@dimen/dimen_space_5"
                android:layout_marginEnd="@dimen/dimen_space_5"
                android:background="@color/chocolate"

                />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerScenarios"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.8"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"

                />

            <androidx.cardview.widget.CardView
                android:id="@+id/card_add_scenario"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.13"
                app:cardBackgroundColor="@color/chocolate"
                app:cardUseCompatPadding="true">

                <TextView
                    android:id="@+id/text_item"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:padding="@dimen/dimen_space_5"
                    android:text="@string/add_scen"
                    android:textColor="@color/white"
                    android:textSize="20sp" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/card_empty"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/card_scenarios"
        app:layout_constraintStart_toStartOf="@+id/card_scenarios"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="5dp"
            android:textColor="@color/white"
            android:text="@string/scenarios_empty"
            android:textSize="16sp" />
    </androidx.cardview.widget.CardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerScenarioDevices"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/dimen_space_5"
        android:layout_marginTop="@dimen/dimen_space_5"
        android:layout_marginEnd="@dimen/dimen_space_10"
        android:layout_marginBottom="@dimen/dimen_space_5"
        app:layoutManager="com.google.android.flexbox.FlexboxLayoutManager"
        app:layout_constraintBottom_toTopOf="@+id/include_bottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/card_scenarios"
        app:layout_constraintTop_toBottomOf="@+id/include_top"

        />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/add_device"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_margin="@dimen/dimen_space_5"
        android:contentDescription="@string/content_description"
        android:foregroundGravity="center"
        android:src="@drawable/ic_baseline_add_24"
        app:backgroundTint="?attr/ToolbarBackground"
        app:backgroundTintMode="src_over"
        app:fabCustomSize="70dp"
        app:layout_constraintBottom_toTopOf="@+id/include_bottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:maxImageSize="55dp" />

    <include
        android:id="@+id/include_bottom"
        layout="@layout/bar_bottom"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
