<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <androidx.cardview.widget.CardView
        android:id="@+id/card_rooms"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        app:cardBackgroundColor="@color/divider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">


            <TextView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.07"
                android:gravity="center"
                android:text="@string/smart_rooms"
                android:textColor="@color/white"
                android:textSize="25sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="@dimen/dimen_space_5"
                android:layout_marginEnd="@dimen/dimen_space_5"
                android:background="@color/chocolate"

                />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerRooms"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.8"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"

                />

            <androidx.cardview.widget.CardView
                android:id="@+id/card_add_room"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.13"
                app:cardBackgroundColor="@color/chocolate"
                app:cardUseCompatPadding="true">

                <TextView
                    android:id="@+id/text_item"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:padding="@dimen/dimen_space_5"
                    android:text="@string/add_room"
                    android:textColor="@color/white"
                    android:textSize="20sp" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/card_empty"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/card_rooms"
        app:layout_constraintStart_toStartOf="@+id/card_rooms"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="5dp"
            android:textColor="@color/white"
            android:text="@string/rooms_empty"
            android:textSize="16sp" />
    </androidx.cardview.widget.CardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerRoomDevices"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/dimen_space_5"
        android:layout_marginEnd="@dimen/dimen_space_5"
        app:layoutManager="com.google.android.flexbox.FlexboxLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/card_rooms"
        app:layout_constraintTop_toTopOf="parent"

        />


</androidx.constraintlayout.widget.ConstraintLayout>