<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <include
        android:id="@+id/include_top"
        layout="@layout/bar_top"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/dimen_space_5"
        android:layout_marginTop="@dimen/dimen_space_10"
        android:layout_marginEnd="@dimen/dimen_space_5"
        android:layout_marginBottom="@dimen/dimen_space_10"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/include_bottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/include_top"
        android:baselineAligned="false">


        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.3">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/settings_btn_settings"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.2"
                        android:scaleType="fitCenter"
                        android:padding="8dp"
                        android:src="@drawable/ic_device_settings"
                        android:contentDescription="@string/content_description"/>
                    <TextView

                        android:layout_width="0dp"
                        android:layout_weight="0.7"
                        android:layout_height="match_parent"
                        android:padding="5dp"
                        android:text="@string/settings_lbldevsettings"
                        android:textAllCaps="false"
                        android:gravity="center|start"
                        android:textSize="18sp" />
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.1"
                        android:scaleType="fitCenter"
                        android:padding="@dimen/dimen_space_5"
                        android:src="@drawable/ic_forward"
                        android:contentDescription="@string/content_description"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:layout_height="2dp"
                    android:background="?attr/ColorDarkLight" />


                <LinearLayout
                    android:id="@+id/settings_btn_network"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginTop="@dimen/dimen_space_5"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.2"
                        android:scaleType="fitCenter"
                        android:padding="8dp"
                        android:src="@drawable/ic_network"
                        android:contentDescription="@string/content_description"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="0.7"
                        android:layout_height="match_parent"
                        android:padding="5dp"
                        android:text="@string/network_settings"
                        android:textAllCaps="false"
                        android:gravity="center|start"
                        android:textSize="18sp" />

                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.1"
                        android:scaleType="fitCenter"
                        android:padding="@dimen/dimen_space_5"
                        android:src="@drawable/ic_forward"
                        android:contentDescription="@string/content_description"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:layout_height="2dp"
                    android:background="?attr/ColorDarkLight" />

                <LinearLayout
                    android:id="@+id/settings_btn_rings"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginTop="@dimen/dimen_space_5"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.2"
                        android:scaleType="fitCenter"
                        android:padding="@dimen/dimen_space_10"
                        android:src="@drawable/ic_ring"
                        android:contentDescription="@string/content_description"/>
                    <TextView

                        android:layout_width="0dp"
                        android:layout_weight="0.7"
                        android:layout_height="match_parent"
                        android:padding="5dp"
                        android:text="@string/settings_lblringettings"
                        android:textAllCaps="false"
                        android:gravity="center|start"
                        android:textSize="18sp" />
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.1"
                        android:scaleType="fitCenter"
                        android:padding="@dimen/dimen_space_5"
                        android:src="@drawable/ic_forward"
                        android:contentDescription="@string/content_description"/>
                </LinearLayout>
                <View
                    android:layout_width="match_parent"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:layout_height="2dp"
                    android:background="?attr/ColorDarkLight" />

                <LinearLayout
                    android:id="@+id/settings_btn_device_name"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginTop="@dimen/dimen_space_5"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.2"
                        android:scaleType="fitCenter"
                        android:padding="10dp"
                        android:src="@drawable/ic_edit"
                        android:contentDescription="@string/content_description"/>
                    <TextView

                        android:layout_width="0dp"
                        android:layout_weight="0.7"
                        android:layout_height="match_parent"
                        android:padding="5dp"
                        android:text="@string/device_name"
                        android:textAllCaps="false"
                        android:gravity="center|start"
                        android:textSize="18sp" />
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.1"
                        android:scaleType="fitCenter"
                        android:padding="@dimen/dimen_space_5"
                        android:src="@drawable/ic_forward"
                        android:contentDescription="@string/content_description"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:layout_height="2dp"
                    android:background="?attr/ColorDarkLight" />

                <LinearLayout
                    android:id="@+id/settings_btn_screen"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginTop="@dimen/dimen_space_5"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.2"
                        android:scaleType="fitCenter"
                        android:padding="@dimen/dimen_space_5"
                        android:src="@drawable/ic_theme"
                        android:contentDescription="@string/content_description"/>
                    <TextView

                        android:layout_width="0dp"
                        android:layout_weight="0.7"
                        android:layout_height="match_parent"
                        android:padding="5dp"
                        android:text="@string/screen_settings"
                        android:textAllCaps="false"
                        android:gravity="center|start"
                        android:textSize="18sp" />
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.1"
                        android:scaleType="fitCenter"
                        android:padding="@dimen/dimen_space_5"
                        android:src="@drawable/ic_forward"
                        android:contentDescription="@string/content_description"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:layout_height="2dp"
                    android:background="?attr/ColorDarkLight" />

                <LinearLayout
                    android:id="@+id/settings_btn_weather"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginTop="@dimen/dimen_space_5"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.2"
                        android:contentDescription="@string/content_description"
                        android:padding="@dimen/dimen_space_5"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_weather" />

                    <TextView

                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.7"
                        android:gravity="center|start"
                        android:padding="5dp"
                        android:text="@string/weather_settings"
                        android:textAllCaps="false"
                        android:textSize="18sp" />

                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.1"
                        android:contentDescription="@string/content_description"
                        android:padding="@dimen/dimen_space_5"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_forward" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:layout_height="2dp"
                    android:background="?attr/ColorDarkLight" />

                <LinearLayout
                    android:id="@+id/settings_btn_date"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginTop="@dimen/dimen_space_5"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.2"
                        android:scaleType="fitCenter"
                        android:padding="@dimen/dimen_space_10"
                        android:src="@drawable/ic_date_time"
                        android:contentDescription="@string/content_description"/>
                    <TextView

                        android:layout_width="0dp"
                        android:layout_weight="0.7"
                        android:layout_height="match_parent"
                        android:padding="5dp"
                        android:text="@string/date_time"
                        android:textAllCaps="false"
                        android:gravity="center|start"
                        android:textSize="18sp" />
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.1"
                        android:scaleType="fitCenter"
                        android:padding="@dimen/dimen_space_5"
                        android:src="@drawable/ic_forward"
                        android:contentDescription="@string/content_description"/>
                </LinearLayout>


                <View
                    android:layout_width="match_parent"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:layout_height="2dp"
                    android:background="?attr/ColorDarkLight" />

                <LinearLayout
                    android:id="@+id/settings_btn_smart"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginTop="@dimen/dimen_space_5"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.2"
                        android:scaleType="fitCenter"
                        android:padding="@dimen/dimen_space_5"
                        android:src="@drawable/ic_smart_home"
                        android:contentDescription="@string/content_description"/>
                    <TextView

                        android:layout_width="0dp"
                        android:layout_weight="0.7"
                        android:layout_height="match_parent"
                        android:padding="5dp"
                        android:text="@string/smarthome"
                        android:textAllCaps="false"
                        android:gravity="center|start"
                        android:textSize="18sp" />
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.1"
                        android:scaleType="fitCenter"
                        android:padding="@dimen/dimen_space_5"
                        android:src="@drawable/ic_forward"
                        android:contentDescription="@string/content_description"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:layout_height="2dp"
                    android:background="?attr/ColorDarkLight"
                    android:visibility="gone"/>



                <View
                    android:layout_width="match_parent"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:layout_height="2dp"
                    android:background="?attr/ColorDarkLight" />

                <LinearLayout
                    android:id="@+id/settings_btn_manuel"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginTop="@dimen/dimen_space_5"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.2"
                        android:scaleType="fitCenter"
                        android:padding="@dimen/dimen_space_10"
                        android:src="@drawable/ic_manual"
                        android:contentDescription="@string/content_description"/>
                    <TextView

                        android:layout_width="0dp"
                        android:layout_weight="0.7"
                        android:layout_height="match_parent"
                        android:padding="5dp"
                        android:text="@string/manual"
                        android:textAllCaps="false"
                        android:gravity="center|start"
                        android:textSize="18sp" />
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.1"
                        android:scaleType="fitCenter"
                        android:padding="@dimen/dimen_space_5"
                        android:src="@drawable/ic_forward"
                        android:contentDescription="@string/content_description"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:layout_height="2dp"
                    android:background="?attr/ColorDarkLight" />

                <LinearLayout
                    android:id="@+id/settings_btn_about"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginTop="@dimen/dimen_space_5"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.2"
                        android:scaleType="fitCenter"
                        android:padding="8dp"
                        android:src="@drawable/ic_info"
                        android:contentDescription="@string/content_description"/>
                    <TextView

                        android:layout_width="0dp"
                        android:layout_weight="0.7"
                        android:layout_height="match_parent"
                        android:padding="5dp"
                        android:text="@string/settings_lblabout"
                        android:textAllCaps="false"
                        android:gravity="center|start"
                        android:textSize="18sp" />
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.1"
                        android:scaleType="fitCenter"
                        android:padding="@dimen/dimen_space_5"
                        android:src="@drawable/ic_forward"
                        android:contentDescription="@string/content_description"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp"
                    android:layout_height="2dp"
                    android:background="?attr/ColorDarkLight" />

                <LinearLayout
                    android:id="@+id/settings_btn_reset"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginTop="@dimen/dimen_space_5"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.2"
                        android:scaleType="fitCenter"
                        android:padding="8dp"
                        android:src="@drawable/ic_factory_reset"
                        android:contentDescription="@string/content_description"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="0.7"
                        android:layout_height="match_parent"
                        android:padding="5dp"
                        android:text="@string/factory_set"
                        android:textAllCaps="false"
                        android:gravity="center|start"
                        android:textSize="18sp" />
                    <ImageView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.1"
                        android:scaleType="fitCenter"
                        android:padding="@dimen/dimen_space_5"
                        android:src="@drawable/ic_forward"
                        android:contentDescription="@string/content_description"/>
                </LinearLayout>


            </LinearLayout>


        </ScrollView>


        <RelativeLayout
            android:id="@+id/frag_depo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="5dp"
            android:layout_weight="0.7" />

    </LinearLayout>

    <include
        android:id="@+id/include_bottom"
        layout="@layout/bar_bottom"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
