<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/black">


    <include
        android:id="@+id/include_top"
        layout="@layout/bar_top_call"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/dimen_space_5"
        android:layout_marginTop="@dimen/dimen_space_10"
        android:layout_marginEnd="@dimen/dimen_space_5"
        android:layout_marginBottom="@dimen/dimen_space_10"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/include_bottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/include_top"
        android:baselineAligned="false">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.15"
            android:orientation="vertical"
            android:gravity="center">


            <ImageView
                android:id="@+id/imgMicrophone"
                android:layout_width="80dp"
                android:layout_height="70dp"
                android:layout_marginTop="@dimen/dimen_space_5"
                android:layout_marginBottom="@dimen/dimen_space_5"
                android:contentDescription="@string/content_description"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_microphone_disable" />



            <ImageView
                android:id="@+id/imgOpenDoor"
                android:layout_width="80dp"
                android:layout_height="70dp"
                android:layout_marginTop="@dimen/dimen_space_5"
                android:layout_marginBottom="@dimen/dimen_space_5"
                android:contentDescription="@string/content_description"
                android:padding="3dp"
                android:src="@drawable/ic_key_disable" />

            <LinearLayout
                android:id="@+id/layout_relay1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_space_5"
                android:layout_marginBottom="@dimen/dimen_space_5"
                android:contentDescription="@string/content_description"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone"
                tools:ignore="UseCompoundDrawables"
                tools:visibility="visible">

                <ImageView
                    android:id="@+id/imgOpenDoor1"
                    android:layout_width="80dp"
                    android:layout_height="65dp"
                    android:contentDescription="@string/content_description"
                    android:src="@drawable/ic_key_disable" />

                <TextView
                    android:id="@+id/txt_relay1_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/content_description"
                    android:gravity="center"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:text="@string/outdoor1"
                    android:textColor="@color/white" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_relay2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_space_5"
                android:layout_marginBottom="@dimen/dimen_space_5"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone"
                tools:ignore="UseCompoundDrawables"
                tools:visibility="visible">

                <ImageView
                    android:id="@+id/imgOpenDoor2"
                    android:layout_width="80dp"
                    android:layout_height="65dp"
                    android:contentDescription="@string/content_description"
                    android:src="@drawable/ic_key_disable" />

                <TextView
                    android:id="@+id/txt_relay2_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:text="@string/outdoor2"
                    android:textColor="@color/white" />

            </LinearLayout>

            <ImageView
                android:id="@+id/imgTakePhoto"
                android:layout_width="80dp"
                android:layout_height="70dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="@dimen/dimen_space_5"
                android:src="@drawable/ic_camera_disable"
                android:contentDescription="@string/content_description"
                android:padding="5dp"
                />

            <ImageView
                android:id="@+id/imgLedOnOff"
                android:layout_width="80dp"
                android:layout_height="70dp"
                android:layout_marginTop="@dimen/dimen_space_5"
                android:layout_marginBottom="@dimen/dimen_space_5"
                android:contentDescription="@string/content_description"
                android:src="@drawable/ic_light_disable"
                />

        </LinearLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.7"
            android:orientation="vertical"
            android:gravity="center"
            >
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextureView
                    android:id="@+id/remoteVideo"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="visible"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>


                <TextureView
                    android:id="@+id/selfVideo"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="visible"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    />

                <TextView
                    android:id="@+id/text_new_call"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:padding="10dp"
                    android:textSize="22sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginBottom="@dimen/dimen_space_10"
                    android:background="@drawable/button_background2"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:gravity="center" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.15"
            android:orientation="vertical"
            android:gravity="center"
            >

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_answer"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:foregroundGravity="center"
                android:src="@drawable/ic_phone_answer"
                app:backgroundTint="@color/green_new"
                app:backgroundTintMode="src_over"
                app:fabCustomSize="80dp"
                android:layout_marginTop="@dimen/dimen_space_20"
                android:layout_marginBottom="@dimen/dimen_space_20"
                app:maxImageSize="70dp"
                android:contentDescription="@string/todo">
            </com.google.android.material.floatingactionbutton.FloatingActionButton>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_close"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:foregroundGravity="center"
                android:src="@drawable/ic_phone_decline"
                app:backgroundTint="@color/red_new"
                app:backgroundTintMode="src_over"
                android:layout_marginTop="@dimen/dimen_space_20"
                android:layout_marginBottom="@dimen/dimen_space_20"
                android:contentDescription="@string/content_description"
                app:fabCustomSize="80dp"
                app:maxImageSize="70dp">
            </com.google.android.material.floatingactionbutton.FloatingActionButton>

            <ImageView
                android:id="@+id/img_vol_setting"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_marginTop="@dimen/dimen_space_20"
                android:visibility="visible"
                android:src="@drawable/ic_baseline_volume_up_24"
                android:contentDescription="@string/content_description" />

        </LinearLayout>
    </LinearLayout>


    <include
        android:id="@+id/include_bottom"
        layout="@layout/bar_bottom_call"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
