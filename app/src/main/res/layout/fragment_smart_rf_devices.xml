<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <androidx.cardview.widget.CardView
        android:id="@+id/card_devices"
        android:layout_width="220dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:cardBackgroundColor="@color/divider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:layout_width="220dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/smart_devices"
                android:textColor="@color/white"
                android:textSize="25sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="@dimen/dimen_space_5"
                android:layout_marginEnd="@dimen/dimen_space_5"
                android:background="@color/chocolate"

                />

            <androidx.cardview.widget.CardView
                android:id="@+id/card_light"
                android:layout_width="match_parent"
                android:layout_height="53dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">
                    <ImageView
                        android:id="@+id/img_item_light"
                        android:layout_width="25dp"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/content_description"
                        android:scaleType="fitCenter"
                        app:tint="@color/chocolate"
                        android:src="@drawable/ic_circle_green" />
                    <TextView
                        android:layout_width="180dp"
                        android:layout_height="match_parent"
                        android:gravity="start|center"
                        android:padding="@dimen/dimen_space_5"
                        android:text="@string/smart_light"/>


                </LinearLayout>

            </androidx.cardview.widget.CardView>






            <androidx.cardview.widget.CardView
                android:id="@+id/card_shutter"
                android:layout_width="match_parent"
                android:layout_height="53dp"
                app:cardUseCompatPadding="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">
                    <ImageView
                        android:id="@+id/img_item_shutter"
                        android:layout_width="25dp"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/content_description"
                        android:scaleType="fitCenter"
                        app:tint="@color/chocolate"
                        android:src="@drawable/ic_circle_green" />
                    <TextView
                        android:layout_width="180dp"
                        android:layout_height="match_parent"
                        android:gravity="start|center"
                        android:padding="@dimen/dimen_space_5"
                        android:text="@string/smart_shutter"/>


                </LinearLayout>

            </androidx.cardview.widget.CardView>


            <androidx.cardview.widget.CardView
                android:id="@+id/card_thermostat"
                android:layout_width="match_parent"
                android:layout_height="53dp"
                app:cardUseCompatPadding="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">
                    <ImageView
                        android:id="@+id/img_item_thermostat"
                        android:layout_width="25dp"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/content_description"
                        android:scaleType="fitCenter"
                        app:tint="@color/chocolate"
                        android:src="@drawable/ic_circle_green" />
                    <TextView
                        android:layout_width="180dp"
                        android:layout_height="match_parent"
                        android:gravity="start|center"
                        android:padding="@dimen/dimen_space_5"
                        android:text="@string/smart_thermostat"/>


                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_onoff"
                android:layout_width="match_parent"
                android:layout_height="53dp"
                app:cardUseCompatPadding="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">
                    <ImageView
                        android:id="@+id/img_item_onoff"
                        android:layout_width="25dp"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/content_description"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_circle_green"

                        app:tint="@color/chocolate" />
                    <TextView
                        android:layout_width="180dp"
                        android:layout_height="match_parent"
                        android:gravity="start|center"
                        android:padding="@dimen/dimen_space_5"
                        android:text="@string/smart_onoff"/>


                </LinearLayout>

            </androidx.cardview.widget.CardView>


        </LinearLayout>

    </androidx.cardview.widget.CardView>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerRoomDevices"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/dimen_space_5"
        android:layout_marginEnd="@dimen/dimen_space_10"
        android:layout_marginTop="@dimen/dimen_space_5"
        app:layoutManager="com.google.android.flexbox.FlexboxLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@+id/card_devices"

        />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/add_device"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_margin="@dimen/dimen_space_5"
        android:contentDescription="@string/content_description"
        android:foregroundGravity="center"
        android:src="@drawable/ic_baseline_add_24"
        app:backgroundTint="?attr/ToolbarBackground"
        app:backgroundTintMode="src_over"
        app:fabCustomSize="70dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:maxImageSize="55dp" />

</androidx.constraintlayout.widget.ConstraintLayout>