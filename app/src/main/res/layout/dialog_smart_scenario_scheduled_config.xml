<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dialog_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.cardview.widget.CardView
        android:layout_width="720dp"
        android:layout_height="450dp"
        android:layout_marginStart="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout

            android:layout_width="match_parent"
            android:layout_height="match_parent">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/dimen_space_5"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/txt_alert"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:textSize="24sp"
                    android:gravity="center"
                    android:textColor="@color/red_new"
                    android:text="@string/scheduled_scenario_alert"
                    android:visibility="gone" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/text_input_job_name"
                    android:layout_width="wrap_content"
                    android:layout_height="100dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/dimen_space_10"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:hint="@string/job_name"
                    app:counterEnabled="true"
                    app:counterMaxLength="20"
                    app:counterOverflowTextAppearance="@style/counterOverride"
                    app:counterTextAppearance="@style/counterText"
                    app:errorEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/ed_job_name"
                        android:layout_width="350dp"
                        android:layout_height="60dp"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:hint="@string/empty"
                        android:imeOptions="actionDone"
                        android:importantForAutofill="no"
                        android:inputType="textPersonName"
                        android:maxLength="20"
                        android:textAllCaps="false"
                        android:textSize="23sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="160dp"
                        android:layout_height="match_parent"
                        android:textSize="24sp"
                        android:visibility="invisible" />


                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/time"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="140dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/action"
                        android:textSize="24sp" />

                    <LinearLayout
                        android:layout_width="220dp"
                        android:layout_height="match_parent">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/card_spinner"
                            android:layout_width="220dp"
                            android:layout_height="match_parent"
                            android:visibility="visible"
                            app:cardBackgroundColor="?attr/ColorStroke"
                            app:cardUseCompatPadding="true">

                            <Spinner
                                android:id="@+id/sp_job_type"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:textSize="24sp" />
                        </androidx.cardview.widget.CardView>

                        <TextView
                            android:visibility="gone"
                            android:id="@+id/txt_spinner"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="@string/action"
                            android:textSize="24sp" />
                    </LinearLayout>




                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:gravity="center"
                        android:text="@string/active"
                        android:textSize="24sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@color/chocolate" />


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="160dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/job1"
                        android:textSize="22sp" />


                    <TextView
                        android:id="@+id/time1"
                        android:layout_width="100dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textSize="22sp"
                        tools:text="8:30" />


                    <androidx.cardview.widget.CardView
                        android:layout_width="140dp"
                        android:layout_height="match_parent"
                        app:cardBackgroundColor="?attr/ColorStroke"
                        app:cardUseCompatPadding="true">

                        <Spinner
                            android:id="@+id/spinner_action1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:textSize="22sp" />
                    </androidx.cardview.widget.CardView>


                    <LinearLayout
                        android:id="@+id/linear1"
                        android:layout_width="220dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal" />

                    <CheckBox
                        android:id="@+id/checkbox1"
                        style="@style/Widget.App.CheckBox"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginStart="@dimen/dimen_space_40"
                        android:gravity="center"
                        android:scaleX="1.2"
                        android:scaleY="1.2" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="?attr/ColorDarkLight" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="160dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/job2"
                        android:textSize="22sp" />


                    <TextView
                        android:id="@+id/time2"
                        android:layout_width="100dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textSize="22sp"
                        tools:text="8:30" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="140dp"
                        android:layout_height="match_parent"
                        app:cardBackgroundColor="?attr/ColorStroke"
                        app:cardUseCompatPadding="true">

                        <Spinner
                            android:id="@+id/spinner_action2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:textSize="22sp" />
                    </androidx.cardview.widget.CardView>


                    <LinearLayout
                        android:id="@+id/linear2"
                        android:layout_width="220dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal" />

                    <CheckBox
                        android:id="@+id/checkbox2"
                        style="@style/Widget.App.CheckBox"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginStart="@dimen/dimen_space_40"
                        android:gravity="center"
                        android:scaleX="1.2"
                        android:scaleY="1.2" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="?attr/ColorDarkLight" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="160dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/job3"
                        android:textSize="22sp" />


                    <TextView
                        android:id="@+id/time3"
                        android:layout_width="100dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textSize="22sp"
                        tools:text="8:30" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="140dp"
                        android:layout_height="match_parent"
                        app:cardBackgroundColor="?attr/ColorStroke"
                        app:cardUseCompatPadding="true">

                        <Spinner
                            android:id="@+id/spinner_action3"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:textSize="22sp" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:id="@+id/linear3"
                        android:layout_width="220dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal" />

                    <CheckBox
                        android:id="@+id/checkbox3"
                        style="@style/Widget.App.CheckBox"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginStart="@dimen/dimen_space_40"
                        android:gravity="center"
                        android:scaleX="1.2"
                        android:scaleY="1.2" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="?attr/ColorDarkLight" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="@dimen/dimen_space_15"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <Button
                android:textStyle="bold"
                        android:id="@+id/btnCancel"
                        android:layout_width="160dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="@dimen/dimen_space_15"
                        android:layout_marginEnd="@dimen/dimen_space_15"
                        android:background="@drawable/layer3"
                        android:gravity="center"
                        android:text="@string/cancel"
                        android:textAllCaps="true"
                        android:textSize="19sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />


                    <Button
                android:textStyle="bold"
                        android:id="@+id/btnRemove"
                        android:layout_width="160dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="@dimen/dimen_space_15"
                        android:layout_marginEnd="@dimen/dimen_space_15"
                        android:background="@drawable/layer3"
                        android:gravity="center"
                        android:text="@string/delete"
                        android:textAllCaps="true"
                        android:textSize="19sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />


                    <Button
                android:textStyle="bold"
                        android:id="@+id/btnSave"
                        android:layout_width="160dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="@dimen/dimen_space_15"
                        android:layout_marginEnd="@dimen/dimen_space_15"
                        android:background="@drawable/layer3"
                        android:gravity="center"
                        android:text="@string/save"
                        android:textAllCaps="true"
                        android:textSize="19sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />
                </LinearLayout>
            </LinearLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
