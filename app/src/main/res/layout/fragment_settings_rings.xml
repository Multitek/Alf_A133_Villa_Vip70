<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="center_horizontal"
            android:layout_margin="@dimen/dimen_space_5"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="180dp"
                    android:layout_height="match_parent"
                    android:layout_margin="5dp"
                    android:gravity="start|center"
                    android:text="@string/settings_lblsilentmode"
                    android:textSize="22sp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="250dp"
                    android:layout_height="match_parent">
                    <ToggleButton
                        android:id="@+id/toggle_silent"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_margin="5dp"
                        android:layout_gravity="center"
                        android:background="?attr/ToolbarBackground"
                        android:text="ToggleButton"
                        android:textAllCaps="true"
                        android:textSize="22sp" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/dimen_space_30"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="180dp"
                    android:layout_height="match_parent"
                    android:layout_margin="5dp"
                    android:gravity="start|center"
                    android:text="@string/volume"
                    android:textSize="22sp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="250dp"
                    android:layout_height="match_parent">
                    <SeekBar
                        android:id="@+id/seek_volume"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_margin="5dp"
                        android:max="15"
                        tools:progress="1" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:layout_marginTop="@dimen/dimen_space_30"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="180dp"
                    android:layout_height="match_parent"
                    android:layout_margin="5dp"
                    android:gravity="start|center"
                    android:text="Device Volume"
                    android:textSize="22sp" />



                <androidx.cardview.widget.CardView
                    android:layout_width="250dp"
                    android:layout_height="match_parent">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/volume_minus"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginStart="@dimen/dimen_space_5"
                            android:layout_marginEnd="@dimen/dimen_space_5"
                            android:src="@drawable/ic_minus"/>

                        <TextView
                            android:id="@+id/volume_text"
                            android:layout_width="100dp"
                            android:layout_height="match_parent"
                            android:layout_margin="5dp"
                            android:gravity="center"
                            android:text="70"
                            android:textSize="22sp" />

                        <ImageView
                            android:id="@+id/volume_plus"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginStart="@dimen/dimen_space_5"
                            android:layout_marginEnd="@dimen/dimen_space_5"
                            android:src="@drawable/ic_plus"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>
            </LinearLayout>



            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/dimen_space_30"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="180dp"
                    android:layout_height="match_parent"
                    android:layout_margin="5dp"
                    android:gravity="start|center"
                    android:text="@string/ring_door"
                    android:textSize="22sp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="250dp"
                    android:layout_gravity="center_vertical"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:id="@+id/layout_door_ring"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:gravity="start"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/layout_door_ring_click"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/text_door_ring_title"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="0.75"
                                android:gravity="center"
                                android:text="test"
                                android:textSize="20sp" />

                            <ImageView
                                android:id="@+id/img_expand_collapse_door_ring"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_gravity="end"
                                android:layout_weight="0.1"
                                android:contentDescription="@string/content_description"
                                android:padding="3dp"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_expand" />
                        </LinearLayout>
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="3dp"
                            android:layout_marginTop="@dimen/dimen_space_5"
                            android:layout_marginLeft="@dimen/dimen_space_5"
                            android:layout_marginRight="@dimen/dimen_space_5"
                            android:background="@color/peru"
                            />
                        <LinearLayout
                            android:id="@+id/layout_door_ring_items"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/dimen_space_30"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="180dp"
                    android:layout_height="match_parent"
                    android:layout_margin="5dp"
                    android:gravity="start|center"
                    android:text="@string/ring_room"
                    android:textSize="22sp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="250dp"
                    android:layout_gravity="center_vertical"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:id="@+id/layout_room_ring"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:gravity="start"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/layout_room_ring_click"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/text_room_ring_title"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="0.75"
                                android:gravity="center"
                                android:text="test"
                                android:textSize="20sp" />

                            <ImageView
                                android:id="@+id/img_expand_collapse_room_ring"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_gravity="end"
                                android:layout_weight="0.1"
                                android:contentDescription="@string/content_description"
                                android:padding="3dp"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_expand" />
                        </LinearLayout>
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="3dp"
                            android:layout_marginTop="@dimen/dimen_space_5"
                            android:layout_marginLeft="@dimen/dimen_space_5"
                            android:layout_marginRight="@dimen/dimen_space_5"
                            android:background="@color/peru"
                            />
                        <LinearLayout
                            android:id="@+id/layout_room_ring_items"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/dimen_space_30"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="180dp"
                    android:layout_height="match_parent"
                    android:layout_margin="3dp"
                    android:gravity="start|center"
                    android:text="@string/ring_duration"
                    android:textSize="22sp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="250dp"
                    android:layout_gravity="center_vertical"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:id="@+id/layout_ring_duration"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:gravity="start"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/layout_ring_duration_click"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/text_ring_duration_title"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="0.75"
                                android:gravity="center"
                                android:text="test"
                                android:textSize="20sp" />

                            <ImageView
                                android:id="@+id/img_expand_collapse_ring_duration"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_gravity="end"
                                android:layout_weight="0.1"
                                android:contentDescription="@string/content_description"
                                android:padding="3dp"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_expand" />
                        </LinearLayout>
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="3dp"
                            android:layout_marginTop="@dimen/dimen_space_5"
                            android:layout_marginLeft="@dimen/dimen_space_5"
                            android:layout_marginRight="@dimen/dimen_space_5"
                            android:background="@color/peru"
                            />
                        <LinearLayout
                            android:id="@+id/layout_ring_duration_items"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </LinearLayout>

    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>








