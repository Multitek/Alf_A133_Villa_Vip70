<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="90dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">


            <LinearLayout
                android:id="@+id/app_version"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:gravity="center|start"
                    android:text="@string/app_version"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="5dp"
                    android:layout_height="wrap_content"
                    android:text="@string/two_dots"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/txtAppVers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/dimen_space_5"
                    android:layoutDirection="ltr"
                    android:textDirection="ltr"
                    android:layout_marginRight="@dimen/dimen_space_5"
                    android:gravity="center|start"
                    android:textSize="22sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_space_10"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:gravity="center|start"
                    android:text="@string/cpu_serial"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="5dp"
                    android:layout_height="wrap_content"
                    android:text="@string/two_dots"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/txtCpu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/dimen_space_5"
                    android:text="133476"
                    android:layout_marginRight="@dimen/dimen_space_5"
                    android:gravity="center|start"
                    android:layoutDirection="ltr"
                    android:textDirection="ltr"
                    android:textSize="22sp" />

            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_space_10"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:gravity="center|start"
                    android:text="@string/fw_version"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="5dp"
                    android:layout_height="wrap_content"
                    android:text="@string/two_dots"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/txtFwVers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/dimen_space_5"
                    android:layout_marginRight="@dimen/dimen_space_5"
                    android:gravity="center|start"
                    android:layoutDirection="ltr"
                    android:textDirection="ltr"
                    android:textSize="22sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_space_10"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:gravity="center|start"
                    android:text="@string/ip_addr"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="5dp"
                    android:layout_height="wrap_content"
                    android:text="@string/two_dots"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/txtIpAddr"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/dimen_space_5"
                    android:layout_marginRight="5dp"
                    android:gravity="center|start"
                    android:layoutDirection="ltr"
                    android:textDirection="ltr"
                    android:textSize="22sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_space_10"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:gravity="center|start"
                    android:text="@string/base_version"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="5dp"
                    android:layout_height="wrap_content"
                    android:text="@string/two_dots"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/txtBaseVers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/dimen_space_5"
                    android:layout_marginRight="@dimen/dimen_space_5"
                    android:gravity="center|start"
                    android:layoutDirection="ltr"
                    android:textDirection="ltr"
                    android:textSize="22sp" />

            </LinearLayout>




            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_space_10"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:gravity="center|start"
                    android:text="@string/internet"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="5dp"
                    android:layout_height="wrap_content"
                    android:text="@string/two_dots"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/txtInternetState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/dimen_space_5"
                    android:layout_marginRight="@dimen/dimen_space_5"
                    android:gravity="center|start"
                    android:text="@string/checking"
                    android:textSize="22sp" />

            </LinearLayout>
        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>















