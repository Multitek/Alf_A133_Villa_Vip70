<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dialog_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <androidx.cardview.widget.CardView
        android:layout_width="580dp"
        android:layout_height="350dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="180dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        >

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/img_favorite"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_margin="@dimen/dimen_space_5"
                android:contentDescription="@string/content_description"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_favorite"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/img_scenario"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_margin="@dimen/dimen_space_5"
                android:contentDescription="@string/content_description"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_cinema"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/txt_alert"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:visibility="gone"
                android:textColor="@color/red_new"
                android:layout_margin="@dimen/dimen_space_5"
                app:layout_constraintStart_toEndOf="@+id/img_scenario"
                app:layout_constraintEnd_toStartOf="@+id/img_favorite"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="@string/control_knx_input1"/>

            <LinearLayout
                android:id="@+id/layout_top"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/img_scenario"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/dimen_space_5"
                android:gravity="center">

                <LinearLayout
                    android:layout_width="280dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen_space_5"
                    android:layout_marginEnd="@dimen/dimen_space_5"
                    android:gravity="center"

                    android:orientation="vertical">
                    <TextView
                android:textStyle="bold"
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:gravity="center"
                        android:text="@string/select_room"
                        android:textSize="17sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginStart="@dimen/dimen_space_10"
                        android:layout_marginEnd="@dimen/dimen_space_10"
                        android:background="@color/chocolate" />
                    <androidx.cardview.widget.CardView
                        android:layout_width="240dp"
                        android:layout_height="65dp"
                        app:cardBackgroundColor="?attr/ColorDarkLightOnStroke"
                        app:cardUseCompatPadding="true">

                        <Spinner
                            android:id="@+id/spinner"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="visible" />

                        <TextView
                            android:id="@+id/txt_room_name"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:textSize="17sp"
                            android:visibility="gone"
                            tools:text="fkhasjkhfsakkfnask" />
                    </androidx.cardview.widget.CardView>



                </LinearLayout>


                <LinearLayout
                    android:layout_width="280dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dimen_space_5"
                    android:layout_marginStart="@dimen/dimen_space_5"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                android:textStyle="bold"
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:gravity="center"
                        android:text="@string/device_name"
                        android:textSize="17sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginStart="@dimen/dimen_space_10"
                        android:layout_marginEnd="@dimen/dimen_space_10"
                        android:background="@color/chocolate" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="240dp"
                        android:layout_height="65dp"
                        app:cardBackgroundColor="?attr/ColorDarkLightOnStroke"
                        app:cardUseCompatPadding="true">
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/input_device_name"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            app:errorEnabled="true">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/ed_device_name"
                                android:layout_width="230dp"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:gravity="center"
                                android:hint="@string/empty"
                                android:imeOptions="actionDone"
                                android:importantForAutofill="no"
                                android:inputType="textPersonName"
                                android:maxLength="20"
                                android:textAllCaps="false"
                                android:textSize="18sp"
                                tools:text="lightffffffffffsertfadsff" />

                        </com.google.android.material.textfield.TextInputLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>


            </LinearLayout>


            <androidx.cardview.widget.CardView
                android:id="@+id/card_pair"
                android:layout_width="200dp"
                android:layout_height="80dp"
                app:cardBackgroundColor="?attr/ColorDarkLightOnStroke"
                app:layout_constraintBottom_toTopOf="@+id/layout_bottom"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/layout_top"
                app:cardUseCompatPadding="true">

                <TextView
                android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:textSize="18sp"
                    android:text="@string/pair"
                    android:textAllCaps="true"
                    android:drawablePadding="@dimen/dimen_space_5"
                    android:gravity="center"
                    android:layout_gravity="center"
                    app:drawableEndCompat="@drawable/ic_baseline_paired" />
            </androidx.cardview.widget.CardView>



            <LinearLayout
                android:id="@+id/layout_delete"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/layout_top">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/dimen_space_10"
                    android:gravity="center"
                    android:text="@string/delete_smart_device_alert"
                    android:textSize="21sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="60dp"
                    android:layout_marginTop="@dimen/dimen_space_10"
                    android:layout_marginBottom="@dimen/dimen_space_10"
                    android:gravity="center"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent">


                    <Button
                android:textStyle="bold"
                        android:id="@+id/btnYes"
                        style="?android:attr/buttonBarButtonStyle"
                        android:layout_width="160dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="@dimen/dimen_space_15"
                        android:layout_marginEnd="@dimen/dimen_space_15"
                        android:background="@drawable/layer3"
                        android:gravity="center"
                        android:text="@string/yes"
                        android:textAllCaps="true"
                        android:textColor="?attr/ColorDarkLight"
                        android:textSize="19sp" />


                    <Button
                android:textStyle="bold"
                        android:id="@+id/btnNo"
                        style="?android:attr/buttonBarButtonStyle"
                        android:layout_width="160dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="@dimen/dimen_space_15"
                        android:layout_marginEnd="@dimen/dimen_space_15"
                        android:background="@drawable/layer3"
                        android:gravity="center"
                        android:text="@string/no"
                        android:textAllCaps="true"
                        android:textColor="?attr/ColorDarkLight"
                        android:textSize="19sp" />

                </LinearLayout>


            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_bottom"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_marginBottom="@dimen/dimen_space_5"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:gravity="center"
                android:orientation="horizontal">


                <Button
                android:textStyle="bold"
                    android:id="@+id/btnCancel"
                    android:layout_width="160dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="@dimen/dimen_space_15"
                    android:layout_marginEnd="@dimen/dimen_space_15"
                    android:background="@drawable/layer3"
                    android:gravity="center"
                    android:text="@string/cancel"
                    android:textAllCaps="true"
                    android:textSize="19sp"
                    android:textColor="?attr/ColorDarkLight"
                    style="?android:attr/buttonBarButtonStyle" />

                <Button
                android:textStyle="bold"
                    android:id="@+id/btnDelete"
                    android:layout_width="160dp"
                    android:layout_height="60dp"
                    android:layout_marginStart="@dimen/dimen_space_20"
                    android:layout_marginEnd="@dimen/dimen_space_20"
                    android:background="@drawable/layer3"
                    android:backgroundTint="@color/red_new"
                    android:gravity="center"
                    android:text="@string/delete"
                    android:textAllCaps="true"
                    android:textSize="19sp"
                    android:visibility="visible"
                    android:textColor="?attr/ColorDarkLight"
                    style="?android:attr/buttonBarButtonStyle" />

                <Button
                android:textStyle="bold"
                    android:id="@+id/btnSave"
                    android:layout_width="160dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="@dimen/dimen_space_15"
                    android:layout_marginEnd="@dimen/dimen_space_15"
                    android:background="@drawable/layer3"
                    android:backgroundTint="@color/green_new"
                    android:gravity="center"
                    android:text="@string/save"
                    android:textAllCaps="true"
                    android:textSize="19sp"
                    android:textColor="?attr/ColorDarkLight"
                    style="?android:attr/buttonBarButtonStyle" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>






</androidx.constraintlayout.widget.ConstraintLayout>